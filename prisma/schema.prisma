generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  name      String
  role      Role     @default(STAFF)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
}

enum Role {
  ADMIN
  STAFF
}

model Table {
  id          Int         @id @default(autoincrement())
  name        String
  number      Int         @unique
  hourlyPrice Float
  nightPrice  Float?
  status      TableStatus @default(AVAILABLE)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  sessions    Session[]

  @@index([status])
  @@index([number])
}

enum TableStatus {
  AVAILABLE
  OCCUPIED
}

model Session {
  id           Int           @id @default(autoincrement())
  tableId      Int
  table        Table         @relation(fields: [tableId], references: [id])
  startTime    DateTime
  endTime      DateTime?
  totalMinutes Int?
  playCost     Float?
  status       SessionStatus @default(ACTIVE)
  rounds       SessionRound[]
  orders       SessionOrder[]
  payment      Payment?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([tableId, status])
  @@index([status])
  @@index([createdAt])
}

enum SessionStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

model SessionRound {
  id        Int      @id @default(autoincrement())
  sessionId Int
  session   Session  @relation(fields: [sessionId], references: [id])
  roundNum  Int
  startTime DateTime
  endTime   DateTime?
  minutes   Int?
  cost      Float?
  createdAt DateTime @default(now())

  @@index([sessionId])
}

model Category {
  id        Int       @id @default(autoincrement())
  name      String
  active    Boolean   @default(true)
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Product {
  id         Int            @id @default(autoincrement())
  name       String
  price      Float
  categoryId Int
  category   Category       @relation(fields: [categoryId], references: [id])
  stock      Int?
  active     Boolean        @default(true)
  orders     SessionOrder[]
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  @@index([categoryId])
  @@index([active])
}

model SessionOrder {
  id        Int      @id @default(autoincrement())
  sessionId Int
  session   Session  @relation(fields: [sessionId], references: [id])
  productId Int
  product   Product  @relation(fields: [productId], references: [id])
  quantity  Int
  unitPrice Float
  total     Float
  createdAt DateTime @default(now())

  @@index([sessionId])
}

model Payment {
  id          Int           @id @default(autoincrement())
  sessionId   Int           @unique
  session     Session       @relation(fields: [sessionId], references: [id])
  playCost    Float
  orderCost   Float
  discount    Float         @default(0)
  serviceFee  Float         @default(0)
  totalCost   Float
  method      PaymentMethod
  cashAmount  Float?
  cardAmount  Float?
  notes       String?
  cashierName String?
  paidAt      DateTime      @default(now())
  createdAt   DateTime      @default(now())

  @@index([paidAt])
}

enum PaymentMethod {
  CASH
  CARD
  MIXED
}
